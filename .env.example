# AI Employee Agent — Vercel Environment Variables
# Alle diese Variablen müssen in Vercel → Settings → Environment Variables eingetragen werden.
# Diese Datei enthält KEINE echten Werte — nur Platzhalter als Dokumentation.

# ── Google Gemini API ──────────────────────────────────────────────────────────
# Pflichtfeld. Zugriff auf KI-Analyse.
# Erhältlich unter: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PayPal Checkout (Variant B — empfohlen) ───────────────────────────────────
# Client ID ist öffentlich (wird im Frontend genutzt)
# Erhältlich unter: https://developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID=your_paypal_client_id_here

# PayPal Secret ist privat — NIEMALS im Frontend verwenden
PAYPAL_SECRET=your_paypal_secret_here

# 'sandbox' für Tests, 'live' für echte Zahlungen
PAYPAL_ENV=sandbox

# ── Analyse-Token-Signierung ───────────────────────────────────────────────────
# Pflichtfeld ab dieser Version. Mindestens 32 zufällige Zeichen.
# Erzeugen: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your_random_secret_min_32_chars_here

# ── Admin / Owner Panel ────────────────────────────────────────────────────────
# Die E-Mail-Adresse des Admins
OWNER_EMAIL=your_admin_email@example.com

# SHA-256-Hash des Admin-Passworts (KEIN Klartext-Passwort!)
# Erzeugen: node -e "const crypto=require('crypto'); console.log(crypto.createHash('sha256').update('IhrPasswort').digest('hex'))"
OWNER_HASH=your_sha256_password_hash_here
