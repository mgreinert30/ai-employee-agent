{
  "functions": {
    "api/analyse.js":          { "maxDuration": 60 },
    "api/immo.js":             { "maxDuration": 60 },
    "api/initiate-upload.js":  { "maxDuration": 15 },
    "api/send-reset.js":       { "maxDuration": 10 },
    "api/verify-reset.js":     { "maxDuration": 10 },
    "api/chat.js":             { "maxDuration": 15 },
    "api/learn.js":            { "maxDuration": 20 },
    "api/heygen-create.js":    { "maxDuration": 30 },
    "api/heygen-avatars.js":   { "maxDuration": 15 },
    "api/heygen-status.js":    { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/immo.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
